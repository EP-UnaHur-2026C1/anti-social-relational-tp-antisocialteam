# Puerto de ejecución del servidor
PORT=3000

# --- Base de datos ---
# Motor a utilizar: sqlite | mysql | postgres
DB_DIALECT=sqlite

# Solo para SQLite: archivo donde se guarda la base
DB_STORAGE=./database.sqlite

# Para MySQL / Postgres (ignorados si DB_DIALECT=sqlite)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=antisocial
DB_USER=root
DB_PASSWORD=

# --- Reglas de negocio ---
# Ventana de visibilidad de comentarios (en meses).
# Los comentarios más antiguos que este valor no se muestran en los posts.
COMMENT_VISIBILITY_MONTHS=6
